{
  "agentPushNotifEnabled": true,
  "env": {},
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": ["Bash(bd *)", "Bash(bd)", "Skill(superpowers:*)", "Skill(wiki:*)"]
  },
  "enabledPlugins": {
    "revdiff@revdiff": true,
    "revdiff-planning@revdiff": true
  },
  "skipAutoPermissionPrompt": true,
  "theme": "dark"
}
