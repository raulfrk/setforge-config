{
  "agentPushNotifEnabled": true,
  "env": {},
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "echo 'Session started. Invoke the session-flow skill now to load the 7-phase workflow before any work.'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bd *)",
      "Bash(bd)",
      "Skill(superpowers:*)",
      "Skill(wiki:*)"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "theme": "dark"
}
