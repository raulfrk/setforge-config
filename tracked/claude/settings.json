{
  "permissions": {
    "defaultMode": "auto"
  },
  "theme": "dark",
  "outputStyle": "Socratic",
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "llm-wiki": {
      "source": {
        "source": "github",
        "repo": "nvk/llm-wiki"
      }
    }
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "wiki@llm-wiki": true
  },
  "mcpServers": {
    "private-journal": {
      "command": "npx",
      "args": ["github:obra/private-journal-mcp"],
      "env": {
        "PRIVATE_JOURNAL_PATH": "/home/raul/.claude/journal"
      }
    }
  }
}
