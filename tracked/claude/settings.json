{
  "agentPushNotifEnabled": true,
  "env": {},
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bd *)",
      "Bash(bd)",
      "Bash(wt switch *)",
      "Bash(wt list)",
      "Bash(wt list *)",
      "Skill(superpowers:*)",
      "Skill(wiki:*)"
    ],
    "deny": [
      "Bash(git push*)"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "theme": "dark"
}
