{
  "agentPushNotifEnabled": true,
  "env": {},
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "serena-hooks activate --client=claude-code",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "echo 'Session started. Invoke the session-flow skill now to load the 7-phase workflow before any work.'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "serena-hooks cleanup --client=claude-code",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "serena-hooks remind --client=claude-code",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "serena-hooks auto-approve --client=claude-code",
            "type": "command"
          }
        ],
        "matcher": "mcp__serena__*"
      }
    ]
  },
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": ["Bash(bd *)", "Bash(bd)", "Skill(superpowers:*)", "Skill(wiki:*)"]
  },
  "enabledPlugins": {
    "revdiff@revdiff": true,
    "revdiff-planning@revdiff": true
  },
  "skipAutoPermissionPrompt": true,
  "theme": "dark"
}
