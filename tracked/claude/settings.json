{
  "agentPushNotifEnabled": true,
  "env": {
    "BEADS_DIR": "/home/raul/.beads"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "wiki@llm-wiki": true
  },
  "extraKnownMarketplaces": {
    "llm-wiki": {
      "source": {
        "repo": "nvk/llm-wiki",
        "source": "github"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "repo": "obra/superpowers-marketplace",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "outputStyle": "Socratic",
  "permissions": {
    "allow": [
      "Bash(bd *)",
      "Bash(bd)",
      "Skill(superpowers:*)",
      "Skill(wiki:*)"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "theme": "dark"
}
